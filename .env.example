# client/.env.example
# Only needed for production builds where the frontend and backend are on
# different domains/services. In local dev, leave these unset — Vite's
# proxy (see vite.config.js) handles routing to http://localhost:5000.

# Full URL to your deployed backend's /api path
VITE_API_URL=https://your-backend-url.example.com/api

# Origin (no path) of your deployed backend, used for the Socket.io connection
VITE_SOCKET_URL=https://your-backend-url.example.com
